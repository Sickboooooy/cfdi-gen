# CFDI-GEN — Variables de entorno (ejemplo)
# Copia este archivo como .env y completa los valores

# Google Drive OAuth2 — obtener en console.cloud.google.com
# 1. Crear proyecto → APIs & Services → Credentials → OAuth 2.0 Client ID
# 2. Tipo: Web application
# 3. Authorized JavaScript origins: http://localhost:5173
VITE_GOOGLE_CLIENT_ID=

# Modo DEMO — controla watermarks y badges
# true = DEMO activo (archivos marcados como NO VÁLIDO)
# false = Producción
VITE_DEMO_MODE=true

# Proveedor alternativo Grok (xAI) — SOLO en Vercel, sin prefijo VITE_
# Agrega esta clave en Vercel Dashboard → Settings → Environment Variables
# NUNCA usar VITE_GROK_API_KEY (se expondría en el bundle JS público)
GROK_API_KEY=
